# Configuração do Bot do Telegram
# Para produção/implantação na Vercel:
# 1. Vá para o Dashboard do seu projeto na Vercel
# 2. Settings (Configurações) > Environment Variables (Variáveis de Ambiente)
# 3. Adicione as chaves abaixo com seus valores reais

VITE_TELEGRAM_BOT_TOKEN=seu_token_do_bot_aqui
VITE_TELEGRAM_CHAT_ID=seu_id_do_chat_aqui

# Configuração do Supabase
VITE_SUPABASE_URL=sua_url_do_supabase_aqui
VITE_SUPABASE_ANON_KEY=sua_chave_anonima_aqui
# SUPABASE_SERVICE_ROLE_KEY (Deve ser adicionada apenas na Vercel para segurança)
SUPABASE_SERVICE_ROLE_KEY=sua_chave_service_role_aqui